{
  "name": "@nekostack/theme",
  "version": "1.0.0",
  "private": false,
  "license": "Apache-2.0",
  "description": "W3C DTCG design token pipeline — 3 themes × 2 modes, WCAG AA checked. Ships CSS custom properties, typed JS, raw JSON, and an optional Tailwind preset.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./css": "./dist/neko.css",
    "./tailwind": "./dist/tailwind.preset.cjs",
    "./json": "./dist/tokens.json",
    "./preview": "./preview.html"
  },
  "files": [
    "dist",
    "preview.html",
    "docs/*.md",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:tokens": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "preview": "node -e \"console.log('Open packages/theme/preview.html in a browser')\"",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "@nekostack/schema": "^1.0.0"
  },
  "devDependencies": {
    "@nekostack/schema": "*",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
