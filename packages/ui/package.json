{
  "name": "@nekostack/ui",
  "version": "0.1.0",
  "description": "Vanilla CSS component library for the NekoStack portfolio. No JS / React / Tailwind — consumes @nekostack/theme tokens.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./css": "./dist/ui.css",
    "./css/min": "./dist/ui.min.css",
    "./components": "./dist/components.json",
    "./preview": "./preview.html"
  },
  "files": [
    "dist",
    "preview.html",
    "CONVENTIONS.md",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "@nekostack/theme": "^0.1.0"
  },
  "devDependencies": {
    "vitest": "^2.1.8"
  }
}
