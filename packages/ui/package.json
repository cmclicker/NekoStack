{
  "name": "@nekostack/ui",
  "version": "1.0.0",
  "private": false,
  "license": "Apache-2.0",
  "description": "Vanilla CSS component library — 92 components, zero JS/React, token-pure. Consumes @nekostack/theme CSS custom properties.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./css": "./dist/ui.css",
    "./css/min": "./dist/ui.min.css",
    "./components": "./dist/components.json",
    "./preview": "./preview.html"
  },
  "files": [
    "dist",
    "preview.html",
    "docs/*.md",
    "CONVENTIONS.md",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "@nekostack/theme": "^1.0.0",
    "@nekostack/schema": "^1.0.0"
  },
  "devDependencies": {
    "@nekostack/theme": "*",
    "@nekostack/schema": "*",
    "vitest": "^2.1.8"
  }
}
