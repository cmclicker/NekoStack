{
  "name": "@nekostack/lint",
  "version": "0.3.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./base": {
      "types": "./dist/src/configs/base.d.ts",
      "default": "./dist/src/configs/base.js"
    },
    "./strict": {
      "types": "./dist/src/configs/strict.d.ts",
      "default": "./dist/src/configs/strict.js"
    },
    "./react": {
      "types": "./dist/src/configs/react.d.ts",
      "default": "./dist/src/configs/react.js"
    },
    "./nest": {
      "types": "./dist/src/configs/nest.d.ts",
      "default": "./dist/src/configs/nest.js"
    }
  },
  "files": [
    "dist/src",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/rule-tester": "^8.0.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
