{
  "name": "@nekostack/schema",
  "version": "1.0.0",
  "private": false,
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./cli": {
      "types": "./dist/src/cli-integration.d.ts",
      "default": "./dist/src/cli-integration.js"
    }
  },
  "files": [
    "dist/src",
    "docs",
