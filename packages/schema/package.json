  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@redocly/openapi-core": "^1.34.0",
    "@types/node": "^22.10.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1",
    "fast-check": "^3.19.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "zod": "^3.22.0"
  }
}
