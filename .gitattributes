# Normalize line endings to LF in the repository on every platform.
# Stops Windows CRLF churn from polluting diffs going forward.
* text=auto eol=lf

# Binary files git must not touch.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.woff  binary
*.woff2 binary
*.pdf  binary
